# ==============================================================================
# ESCROW ACCOUNT LEDGER — ENVIRONMENT VARIABLE TEMPLATE (.env.example)
# Copy this file to a new file named '.env' and fill in your actual credentials.
# ==============================================================================

# Backend API Endpoint Configuration
VITE_API_BASE_URL=https://your-backend-api-url.com/api

# Firebase Project Configuration
VITE_FIREBASE_API_KEY=AIzaSy...your_firebase_api_key...
VITE_FIREBASE_AUTH_DOMAIN=your-app-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=1:your_messaging_sender_id:web:your_app_hash
VITE_FIREBASE_MEASUREMENT_ID=G-YOUR_MEASUREMENT_ID

# Supabase Serverless & Database Configuration
VITE_SUPABASE_URL=https://your_supabase_project_id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_api_key
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_key
